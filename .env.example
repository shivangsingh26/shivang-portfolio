# AI chatbot — Vercel AI Gateway (recommended)
# Local dev: `vercel link` then `vercel env pull` to fetch a temporary OIDC token automatically.
# Or paste a gateway key here:
# AI_GATEWAY_API_KEY=

# Optional overrides
# AI_GATEWAY_BASE_URL=
# AI_MODEL=openai/gpt-5.4

# Admin stats page (any random string; visit /admin/stats?token=<value>)
ADMIN_TOKEN=change-me-to-something-random
